# --- LLM Provider ---
# Options: ollama (default), nvidia
LLM_PROVIDER=ollama
# Model name (ollama: "mistral", nvidia: "nvidia/nemotron-3-super-120b-a12b")
LLM_MODEL=mistral
# Optional base URL for local deployments (ollama: http://localhost:11434, nvidia: http://localhost:8000/v1)
# LLM_BASE_URL=
# NVIDIA API key (required if LLM_PROVIDER=nvidia)
# NVIDIA_API_KEY=nvapi-...

# --- Chunking ---
# CHUNK_STRATEGY=compliance
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# --- Embeddings ---
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Indexing ---
# INDEX_DIR=index_cache

# --- Retrieval ---
# RETRIEVAL_TOP_K=5
# RETRIEVAL_HYBRID=false
# RETRIEVAL_HYBRID_ALPHA=0.7

# --- Agent ---
# AGENT_MAX_RETRIES=2
# AGENT_MAX_HOPS=3

# --- Generation ---
# GENERATION_MAX_CONTEXT=3000
# GENERATION_MAX_TOKENS=2048

# --- Observability ---
# OBSERVABILITY_ENABLED=true
