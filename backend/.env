# --- LLM Provider (NVIDIA NIM only) ---
# Model name, default: nvidia/nemotron-3-super-120b-a12b
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
# Base URL for local NIM deployment (omit for NVIDIA cloud API Catalog)
# LLM_BASE_URL=http://localhost:8000/v1
# NVIDIA API key (required)
NVIDIA_API_KEY="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"

# --- Chunking ---
# CHUNK_STRATEGY=compliance
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# --- Embeddings ---
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Indexing ---
# INDEX_DIR=index_cache

# --- Retrieval ---
# RETRIEVAL_TOP_K=5
# RETRIEVAL_HYBRID=false
# RETRIEVAL_HYBRID_ALPHA=0.7

# --- Agent ---
# AGENT_MAX_RETRIES=2
# AGENT_MAX_HOPS=3

# --- Generation ---
# GENERATION_MAX_CONTEXT=3000
# GENERATION_MAX_TOKENS=2048

# --- Observability ---
# OBSERVABILITY_ENABLED=true
